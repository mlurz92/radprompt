  "categories": ["productivity", "utilities"],
  "prefer_related_applications": false,
  "icons": [
    { "src": "/assets/icons/favicon.svg", "type": "image/svg+xml", "sizes": "any", "purpose": "any" },
    { "src": "/assets/icons/favicon.svg", "type": "image/svg+xml", "sizes": "any", "purpose": "maskable" },
    { "src": "/assets/icons/favicon.svg", "type": "image/svg+xml", "sizes": "any", "purpose": "monochrome" }
  ]
}

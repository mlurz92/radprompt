{
  "id": "/",
  "name": "RadPrompt",
  "short_name": "RadPrompt",
  "description": "Kompaktes radiologisches Prompt-Button-Dashboard für Windows 11.",
  "start_url": "/",
  "scope": "/",
  "lang": "de-DE",
  "dir": "ltr",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "any",
